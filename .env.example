# Default provider alias used when request.model is omitted.
LLM_SHIM_DEFAULT_PROVIDER="default"

# Provider map
# Each configured provider requires MODEL in provider/model format.
LLM_SHIM_PROVIDERS__default__MODEL="openai/gpt-4.1"
LLM_SHIM_PROVIDERS__default__API_KEY="sk-..."
# Optional: custom base URL for OpenAI-compatible gateways
# LLM_SHIM_PROVIDERS__default__BASE_URL="https://api.openai.com/v1"
# Optional: Instructor mode override (provider-specific)
# LLM_SHIM_PROVIDERS__default__MODE=

# Add more provider aliases if needed
# LLM_SHIM_PROVIDERS__cheap__MODEL="google/gemini-3-flash-preview"
# LLM_SHIM_PROVIDERS__cheap__API_KEY="sk-..."

# Server configuration
LLM_SHIM_SERVER__HOST="0.0.0.0"
LLM_SHIM_SERVER__PORT="8000"
LLM_SHIM_SERVER__RELOAD="false"
LLM_SHIM_SERVER__WORKERS="1"
LLM_SHIM_SERVER__LOG_LEVEL="info"
